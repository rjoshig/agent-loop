{
  "name": "agent-loop",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-agent orchestration for credit-bureau customer onboarding (CSC + Compliance + Tech).",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "src/index.js",
  "bin": {
    "agent-loop": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.js\" \"docs/**/*.md\" \"REQUIREMENTS/**/*.md\" \"README.md\"",
    "format:check": "prettier --check \"src/**/*.js\" \"docs/**/*.md\" \"REQUIREMENTS/**/*.md\" \"README.md\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.1",
    "@langchain/langgraph": "^0.4.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.17.0",
    "globals": "^15.15.0",
    "prettier": "^3.4.2"
  }
}
