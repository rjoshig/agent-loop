# --- LLM provider switch ----------------------------------------------------
# Choose which provider runs the three agents. Both paths are wired up by
# src/agents/base.js; the rest of the codebase is provider-agnostic.
#
#   anthropic → uses @anthropic-ai/sdk against api.anthropic.com
#   grok      → uses the openai SDK against api.x.ai (xAI is OpenAI-compatible)
LLM_PROVIDER=anthropic

# Optional model override. Defaults pick a sensible model per provider:
#   anthropic → claude-sonnet-4-5
#   grok      → grok-4
# LLM_MODEL=claude-sonnet-4-5
# LLM_MODEL=grok-4

# Optional base-URL override. Useful if you want to point at a self-hosted
# OpenAI-compatible gateway, an enterprise proxy, or another OpenAI-compatible
# provider. When LLM_PROVIDER=grok and this is unset, defaults to
# https://api.x.ai/v1.
# LLM_BASE_URL=https://api.x.ai/v1

# --- Provider credentials ---------------------------------------------------
# Required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=sk-ant-...

# Required when LLM_PROVIDER=grok. Get a key at https://console.x.ai
# XAI_API_KEY=xai-...

# --- Run-time toggles -------------------------------------------------------
# Skip the interactive human gate (auto-approve). Useful for demos and CI.
# AUTO_APPROVE_HUMAN_GATE=false
